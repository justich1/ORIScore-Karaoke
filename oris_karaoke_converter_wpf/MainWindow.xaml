<Window x:Class="OrisKaraokeConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ORIScore KaraFun KFN Converter"
        Width="1220"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        Foreground="#EAF2FF" Icon="/converter.png">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#121D2F" />
        <SolidColorBrush x:Key="PanelBrush2" Color="#17243A" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#263852" />
        <SolidColorBrush x:Key="AccentBrush" Color="#36D1FF" />
        <SolidColorBrush x:Key="AccentBrush2" Color="#6EE7B7" />
        <SolidColorBrush x:Key="TextSoftBrush" Color="#AFC3DD" />
        <SolidColorBrush x:Key="InputBrush" Color="#0F1A2B" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="CaretBrush" Value="#EAF2FF" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D7E7FA" />
            <Setter Property="Margin" Value="0,0,18,10" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="OrisButton" TargetType="Button">
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="Background" Value="#20324D" />
            <Setter Property="BorderBrush" Value="#36506F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#284064" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#16263E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource OrisButton}">
            <Setter Property="Background" Value="#0E7490" />
            <Setter Property="BorderBrush" Value="#38BDF8" />
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource OrisButton}">
            <Setter Property="Background" Value="#047857" />
            <Setter Property="BorderBrush" Value="#6EE7B7" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="#EAF2FF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#22344E" />
            <Setter Property="RowBackground" Value="#101B2C" />
            <Setter Property="AlternatingRowBackground" Value="#132035" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1B2B44" />
            <Setter Property="Foreground" Value="#D7E7FA" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#2A3F5F" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding RowBrush}" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush2}" />
            <Setter Property="Background" Value="#0F1A2B" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="155" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="20" Padding="18" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#102338" Offset="0" />
                    <GradientStop Color="#0B1220" Offset="0.62" />
                    <GradientStop Color="#063F4F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ORIScore KaraFun KFN Converter" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="KFN → .ock, audio do podsložky zaklad, index pro rádio" Foreground="{StaticResource TextSoftBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Vstupní složka" />
                    <TextBox x:Name="InputDirBox" Grid.Column="1" />
                    <Button x:Name="BrowseInputButton" Grid.Column="2" Style="{StaticResource OrisButton}" Content="Procházet" Margin="10,0,0,0" Click="BrowseInputButton_Click" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Výstupní složka" />
                    <TextBox x:Name="OutputDirBox" Grid.Column="1" />
                    <Button x:Name="BrowseOutputButton" Grid.Column="2" Style="{StaticResource OrisButton}" Content="Procházet" Margin="10,0,0,0" Click="BrowseOutputButton_Click" />
                </Grid>

                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <CheckBox x:Name="RecursiveBox" Content="Hledat KFN i v podsložkách" IsChecked="True" ToolTip="Najde .kfn i ve vnořených složkách vstupní složky." />
                    <CheckBox x:Name="CopyAudioBox" Content="Zkopírovat MP3/WAV do zaklad" IsChecked="True" ToolTip="Zapnuto = audio se uloží do podsložky zaklad vedle .ock." />
                    <CheckBox x:Name="OverwriteBox" Content="Přepsat existující výstupy" IsChecked="False" ToolTip="Když už výstup existuje, přepíše ho novou konverzí." />
                    <CheckBox x:Name="PreserveFoldersBox" Content="Zachovat strom složek" ToolTip="Ve výstupu zachová stejné podsložky jako ve vstupu." />
                    <CheckBox x:Name="CreateIndexBox" Content="Vytvořit index pro rádio" IsChecked="False" ToolTip="Vytvoří karaoke.index.json se seznamem skladeb." />
                    <CheckBox x:Name="PromptMissingAudioBox" Content="Při chybějícím audiu se zeptat" IsChecked="True" ToolTip="Otevře výběr správného MP3/WAV, pokud Source cesta neexistuje." />

                    <Button x:Name="ScanButton" Style="{StaticResource PrimaryButton}" Content="1) Skenovat" Width="125" Margin="0,0,10,10" Click="ScanButton_Click" />
                    <Button x:Name="ConvertButton" Style="{StaticResource SuccessButton}" Content="2) Konvertovat" Width="145" Margin="0,0,10,10" Click="ConvertButton_Click" />
                    <Button x:Name="HelpButton" Style="{StaticResource OrisButton}" Content="Co to je?" Width="95" Margin="0,0,0,10" Click="HelpButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="KfnGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      AlternationCount="2"
                      MouseDoubleClick="KfnGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="KFN" Binding="{Binding KfnPath}" Width="2*" />
                    <DataGridTextColumn Header="Audio" Binding="{Binding AudioPath}" Width="2*" />
                    <DataGridTextColumn Header="Stav" Binding="{Binding Status}" Width="1.2*" />
                    <DataGridTextColumn Header="Výstup" Binding="{Binding OutputPath}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ProgressBar x:Name="Progress" Grid.Row="0" Minimum="0" Maximum="1" Value="0" />
                <TextBox x:Name="LogBox"
                         Grid.Row="2"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True" />
            </Grid>
        </Border>
    </Grid>
</Window>
