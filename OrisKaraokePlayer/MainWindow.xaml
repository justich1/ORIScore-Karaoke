<Window x:Class="OrisKaraokePlayerWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ORIScore Karaoke Player"
        Width="1400"
        Height="820"
        MinWidth="900"
        MinHeight="560"
        Background="#060910"
        Foreground="#EEF3FF"
        KeyDown="Window_KeyDown" Icon="/player.png">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1B2535"/>
            <Setter Property="Foreground" Value="#EEF3FF"/>
            <Setter Property="BorderBrush" Value="#31445F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEF3FF"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#AAB8CC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="14,0,0,0"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="8,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#090E16" BorderBrush="#1E2A3A" BorderThickness="0,0,0,1">
            <Grid Margin="12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Otevřít" Click="OpenJson_Click"/>
                <Button Grid.Column="1" Content="Vybrat audio" Click="PickAudio_Click"/>
                <Button Grid.Column="2" Content="▶ / ⏸" Click="PlayPause_Click"/>
                <Button Grid.Column="3" Content="■" Click="Stop_Click"/>
                <Button Grid.Column="4" Content="Celá obrazovka" Click="Fullscreen_Click"/>

                <TextBlock Grid.Column="6" Text="Offset" VerticalAlignment="Center" Foreground="#AAB8CC"/>
                <TextBox Grid.Column="7" x:Name="OffsetBox" Text="0" Height="30" VerticalContentAlignment="Center"
                         Background="#101927" Foreground="#EEF3FF" BorderBrush="#31445F" TextChanged="OffsetBox_TextChanged"/>

                <TextBlock Grid.Column="8" Text="Hlasitost" VerticalAlignment="Center" Foreground="#AAB8CC"/>
                <Slider Grid.Column="9" x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.85"
                        VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"/>

                <CheckBox Grid.Column="10"
                          x:Name="SmoothScrollCheckBox"
                          Content="Plynulý posun"
                          ToolTip="Plynulé posouvání textu odspodu nahoru"
                          Checked="SmoothScrollCheckBox_Changed"
                          Unchecked="SmoothScrollCheckBox_Changed"/>

                <StackPanel Grid.Column="11" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Otevři karaoke a békej" FontSize="21" FontWeight="Bold"/>
                    <TextBlock x:Name="ArtistText" Text="" Foreground="#9FB0C7" FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="12" x:Name="TimeText" Text="00:00 / 00:00" VerticalAlignment="Center"
                           Foreground="#9FB0C7" FontSize="13"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#0B1020" ClipToBounds="True">
            <Grid x:Name="LyricsViewport" ClipToBounds="True">
                <Grid.Background>
                    <RadialGradientBrush Center="0.5,0.0" GradientOrigin="0.5,0.0" RadiusX="0.9" RadiusY="0.9">
                        <GradientStop Color="#1B355F" Offset="0"/>
                        <GradientStop Color="#0B1020" Offset="0.58"/>
                        <GradientStop Color="#05070C" Offset="1"/>
                    </RadialGradientBrush>
                </Grid.Background>

                <!-- Statický režim zůstává jako dřív: velký aktuální řádek uprostřed, bez plynulého posunu. -->
                <Grid x:Name="StaticLyricsHost">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.1*"/>
                        <RowDefinition Height="2.2*"/>
                        <RowDefinition Height="1.1*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="PrevLineText"
                               Text=""
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#728196"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Opacity="0.65"
                               Margin="40,10"/>

                    <Viewbox Grid.Row="1" Stretch="Uniform" Margin="40,10">
                        <WrapPanel x:Name="WordsPanel"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   MaxWidth="1350"/>
                    </Viewbox>

                    <Viewbox Grid.Row="2"
                             Stretch="Uniform"
                             StretchDirection="Both"
                             Margin="40,10">
                        <TextBlock x:Name="NextLineText"
                                   Text=""
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap"
                                   Foreground="WhiteSmoke"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   Opacity="1"/>
                    </Viewbox>
                </Grid>

                <!-- Plynulý režim: žádné Viewboxy, žádné měnění velikosti při odjíždění řádku. -->
                <Grid x:Name="SmoothLyricsHost" Visibility="Collapsed" ClipToBounds="True">
                    <Grid x:Name="SmoothLyricsMoveHost">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="LyricsMoveTransform"/>
                        </Grid.RenderTransform>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0"
                                   x:Name="SmoothPrevPanel"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="60,8"/>

                        <WrapPanel Grid.Row="1"
                                   x:Name="SmoothCurrentPanel"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="60,8"/>

                        <WrapPanel Grid.Row="2"
                                   x:Name="SmoothNextPanel"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="60,8"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#080C13" BorderBrush="#1E2A3A" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Slider x:Name="SeekSlider"
                        Minimum="0"
                        Maximum="1000"
                        VerticalAlignment="Center"
                        PreviewMouseDown="SeekSlider_PreviewMouseDown"
                        PreviewMouseUp="SeekSlider_PreviewMouseUp"
                        ValueChanged="SeekSlider_ValueChanged"/>
            </Grid>
        </Border>

        <MediaElement x:Name="Player"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Volume="0.85"
                      MediaOpened="Player_MediaOpened"
                      MediaEnded="Player_MediaEnded"
                      MediaFailed="Player_MediaFailed"
                      Visibility="Collapsed"/>
    </Grid>
</Window>
