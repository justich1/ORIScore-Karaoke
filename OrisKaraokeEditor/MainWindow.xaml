<Window x:Class="OrisKaraokeEditorWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ORIS Karaoke Tap Editor v2"
        Width="1460"
        Height="860"
        MinWidth="1050"
        MinHeight="680"
        Background="#060910"
        Foreground="#EEF3FF"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1B2535"/>
            <Setter Property="Foreground" Value="#EEF3FF"/>
            <Setter Property="BorderBrush" Value="#31445F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEF3FF"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#101927"/>
            <Setter Property="Foreground" Value="#EEF3FF"/>
            <Setter Property="BorderBrush" Value="#31445F"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="74"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#090E16" BorderBrush="#1E2A3A" BorderThickness="0,0,0,1">
            <Grid Margin="12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Nové z textu" Click="NewFromText_Click"/>
                <Button Grid.Column="1" Content="Otevřít ock" Click="OpenJson_Click"/>
                <Button Grid.Column="2" Content="Vybrat audio" Click="PickAudio_Click"/>
                <Button Grid.Column="3" Content="Uložit" Click="Save_Click"/>
                <Button Grid.Column="4" Content="Uložit jako" Click="SaveAs_Click"/>
                <Button Grid.Column="5" Content="Reset časů" Click="ResetTimes_Click"/>

                <TextBlock Grid.Column="7" Text="Offset" VerticalAlignment="Center" Foreground="#AAB8CC"/>
                <TextBox Grid.Column="8" x:Name="OffsetBox" Text="0" Height="30" VerticalContentAlignment="Center"
                         TextChanged="OffsetBox_TextChanged"/>

                <StackPanel Grid.Column="10" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Vlož text, vyber audio a odklepávej mezerníkem" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="SubTitleText" Text="Space = zapsat čas dalšího slova, Backspace = krok zpět, Enter = play/pause"
                               Foreground="#9FB0C7" FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="11" x:Name="TimeText" Text="00:00 / 00:00" VerticalAlignment="Center"
                           Foreground="#9FB0C7" FontSize="13"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0B1018" BorderBrush="#1E2A3A" BorderThickness="0,0,1,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Text skladby" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Text="Vlož celý text. Řádky zůstanou jako karaoke řádky, slova se odklepávají mezerníkem."
                               Foreground="#AAB8CC" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Název" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" x:Name="TitleBox" Height="28" VerticalContentAlignment="Center"/>
                    </Grid>

                    <TextBox Grid.Row="3"
                             x:Name="LyricsBox"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="8"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Vytvořit slova z textu" Click="BuildFromText_Click"/>
                        <Button Content="Vložit ukázku" Click="InsertSample_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#0B1020">
                <Grid>
                    <Grid.Background>
                        <RadialGradientBrush Center="0.5,0.0" GradientOrigin="0.5,0.0" RadiusX="0.9" RadiusY="0.9">
                            <GradientStop Color="#1B355F" Offset="0"/>
                            <GradientStop Color="#0B1020" Offset="0.58"/>
                            <GradientStop Color="#05070C" Offset="1"/>
                        </RadialGradientBrush>
                    </Grid.Background>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="90"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="110"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="▶ / ⏸ Enter" Click="PlayPause_Click" FontSize="16"/>
                        <Button Content="SPACE zapsat čas" Click="Stamp_Click" FontSize="16" Background="#1857A8"/>
                        <Button Content="← zpět Backspace" Click="StepBack_Click" FontSize="16"/>
                        <Button Content="Přeskočit slovo" Click="SkipWord_Click" FontSize="16"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock x:Name="PrevLineText"
                                   Text=""
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="#73849B"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Opacity="0.7"
                                   Margin="0,0,0,28"/>

                        <WrapPanel x:Name="CurrentWordsPanel"
                                   HorizontalAlignment="Center"
                                   MaxWidth="900"/>

                        <TextBlock x:Name="NextLineText"
                                   Text=""
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="#73849B"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Opacity="0.7"
                                   Margin="0,28,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="NextWordText"
                                   Text="Další slovo: -"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#FFD95A"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="ProgressText"
                                   Text="0 / 0 slov"
                                   FontSize="14"
                                   Foreground="#AAB8CC"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#0B1018" BorderBrush="#1E2A3A" BorderThickness="1,0,0,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Kontrola řádků a časů" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

                    <DataGrid Grid.Row="1"
                              x:Name="WordsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Background="#111927"
                              Foreground="#EEF3FF"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#111927"
                              AlternatingRowBackground="#0E1623"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding FlatIndex}" Width="48"/>
                            <DataGridTextColumn Header="Řádek" Binding="{Binding LineIndex}" Width="58"/>
                            <DataGridTextColumn Header="Slovo" Binding="{Binding Text}" Width="*"/>
                            <DataGridTextColumn Header="Čas" Binding="{Binding TimeText}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#080C13" BorderBrush="#1E2A3A" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <Slider x:Name="SeekSlider"
                        Minimum="0"
                        Maximum="1000"
                        VerticalAlignment="Center"
                        PreviewMouseDown="SeekSlider_PreviewMouseDown"
                        PreviewMouseUp="SeekSlider_PreviewMouseUp"
                        ValueChanged="SeekSlider_ValueChanged"/>

                <TextBlock Grid.Column="1" x:Name="AudioText"
                           Text="Audio: nevybráno"
                           Foreground="#AAB8CC"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <MediaElement x:Name="Player"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Volume="0.9"
                      MediaOpened="Player_MediaOpened"
                      MediaEnded="Player_MediaEnded"
                      MediaFailed="Player_MediaFailed"
                      Visibility="Collapsed"/>
    </Grid>
</Window>
